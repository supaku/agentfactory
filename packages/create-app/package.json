    },
    "./templates": {
      "types": "./dist/src/templates/index.d.ts",
      "import": "./dist/src/templates/index.js",
      "default": "./dist/src/templates/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.5.4",
    "typescript": "^5.7.3"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build"
  }
}
