{
  "name": "@renseiai/daemon",
  "version": "0.1.0",
  "type": "module",
  "description": "Rensei local daemon — one-per-machine worker pool that replaces per-workspace fleets",
  "author": "Rensei AI (https://rensei.ai)",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RenseiAI/agentfactory.git",
    "directory": "packages/daemon"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "rensei-daemon": "./dist/src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@renseiai/agentfactory": "workspace:*",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "typescript": "^5.7.3",
    "vitest": "^3.2.3"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build"
  }
}
