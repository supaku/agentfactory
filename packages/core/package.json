{
  "name": "@renseiai/agentfactory",
  "version": "0.8.19",
  "type": "module",
  "description": "Multi-agent fleet management for coding agents — orchestrator, providers, crash recovery",
  "author": "Rensei AI (https://rensei.ai)",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RenseiAI/agentfactory.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/RenseiAI/agentfactory/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/RenseiAI/agentfactory/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agent",
    "orchestrator",
    "coding-agent",
    "claude",
    "codex",
    "multi-agent",
    "fleet-management"
  ],
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.7",
    "dotenv": "^17.2.3",
    "handlebars": "^4.7.8",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@renseiai/create-agentfactory-app": "workspace:*",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.5.4",
    "typescript": "^5.7.3",
    "vitest": "^3.2.3"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build"
  }
}
