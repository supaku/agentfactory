#!/bin/sh

# -----------------------------------------------------------
# 1. Prevent .env files from being committed (dotenvx)
# -----------------------------------------------------------
if command -v dotenvx 2>&1 >/dev/null
then
  dotenvx ext precommit
elif npx dotenvx -V >/dev/null 2>&1
then
  npx dotenvx ext precommit
else
  echo "[dotenvx][precommit] 'dotenvx' command not found"
  echo "[dotenvx][precommit] install it with: pnpm add -Dw @dotenvx/dotenvx"
  exit 1
fi

# -----------------------------------------------------------
# 2. Scan staged changes for secrets (gitleaks)
# -----------------------------------------------------------
if command -v gitleaks >/dev/null 2>&1
then
  gitleaks git --pre-commit --staged --verbose
else
  echo "[gitleaks][precommit] 'gitleaks' command not found — skipping secret scan"
  echo "[gitleaks][precommit] install it with: brew install gitleaks"
fi
