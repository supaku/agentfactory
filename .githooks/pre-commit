#!/bin/sh

# Prevent .env files from being committed.
# Powered by dotenvx — https://dotenvx.com/docs/advanced/precommit-install

if command -v dotenvx 2>&1 >/dev/null
then
  dotenvx ext precommit
elif npx dotenvx -V >/dev/null 2>&1
then
  npx dotenvx ext precommit
else
  echo "[dotenvx][precommit] 'dotenvx' command not found"
  echo "[dotenvx][precommit] install it with: pnpm add -Dw @dotenvx/dotenvx"
  exit 1
fi
